-----------------------------------------------------------------------------------------------
--- SILVER LAYER PROCEDURE FOR INSERTING CLEANED BRONZE LAYER DATA INTO SILVER LAYER
-----------------------------------------------------------------------------------------------
--- VERY SIMILIAR TO BRONZE LAYER SP 

CREATE OR REPLACE PROCEDURE silver.load_silver()
LANGUAGE plpgsql
AS $$
DECLARE 
  sd_message TEXT;
  sd_detail  TEXT;
  sd_context TEXT;
  sd_hint TEXT;

  table_rows INTEGER;
  
  l_start_time TIMESTAMPTZ;
  l_end_time TIMESTAMPTZ;
  
  proc_start TIMESTAMPTZ; 
  proc_end TIMESTAMPTZ;
    BEGIN
        proc_start := clock_timestamp();
            RAISE NOTICE '===============================';
            RAISE NOTICE 'loading Silver Layer...';
            RAISE NOTICE '===============================';
        
            RAISE NOTICE '-------------------------------';
            RAISE NOTICE 'Loading CRM tables...';
            RAISE NOTICE '-------------------------------';
-- silver.crm_cust_info table         
        BEGIN
            RAISE NOTICE '>> Truncating table: silver.crm_cust_info.';
            TRUNCATE TABLE silver.crm_cust_info;
      
            RAISE NOTICE '>> Inserting Data Into: silver.crm_cust_info...';
            l_start_time := clock_timestamp();
            INSERT INTO silver.crm_cust_info(
                cst_id,
                cst_key,
                cst_firstname,
                cst_lastname,
                cst_gndr,
                cst_marital_status,
                cst_create_date
                )
                SELECT
                    cst_id,
                    cst_key,
                    TRIM(cst_firstname) AS cst_firstname,
                    TRIM(cst_lastname) AS cst_lastname,
                    CASE
                        WHEN UPPER(TRIM(cst_gndr)) = 'F' THEN 'Female'
                        WHEN UPPER(TRIM(cst_gndr)) = 'M' THEN 'Male'
                        ELSE 'N/A'
                    END AS cst_gndr,
                    CASE
                        WHEN UPPER(TRIM(cst_marital_status)) = 'S' THEN 'Single'
                        WHEN UPPER(TRIM(cst_marital_status)) = 'M' THEN 'Married'
                        ELSE 'N/A'
                    END AS cst_marital_status,
                    cst_create_date
                FROM (
                    SELECT
                        *,
                        ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag
                    FROM bronze.crm_cust_info
                    WHERE cst_id IS NOT NULL
                    )t
                WHERE flag = 1;
            l_end_time := clock_timestamp();
            GET DIAGNOSTICS table_rows = ROW_COUNT;
            RAISE NOTICE '>> silver.crm_cust_info complete. Loaded % rows in: %',
                table_rows, l_end_time - l_start_time;               
        EXCEPTION 
            WHEN OTHERS THEN
            RAISE NOTICE 'silver.crm_cust_info failed.';
            GET STACKED DIAGNOSTICS 
                sd_message = MESSAGE_TEXT,
                sd_detail = PG_EXCEPTION_DETAIL,
                sd_context = PG_EXCEPTION_CONTEXT,
                sd_hint = PG_EXCEPTION_HINT;
            RAISE EXCEPTION 
                'Table: silver.crm_cust_info
                 SQLSTATE: %
                 Message: %
                 Detail: %
                 error_line: %
                 error_hint: %',
                SQLSTATE, sd_message, sd_detail, sd_context, sd_hint;
        END;
-- silver.crm_prd_info table 
        BEGIN
            RAISE NOTICE '>>Truncating table: silver.crm_prd_info';
            TRUNCATE TABLE silver.crm_prd_info;
            
            RAISE NOTICE '>>Inserting Data Into: silver.crm_prd_info';
            l_start_time := clock_timestamp();
            INSERT INTO silver.crm_prd_info(
                prd_id,
                cat_id,
                prd_key,
                prd_nm,
                prd_cost,
                prd_line,
                prd_start_dt,
                prd_end_dt
                )
                SELECT
                    prd_id,
                    REPLACE(SUBSTRING(prd_key,1,5), '-', '_') AS cat_id,
                    SUBSTRING(prd_key,7,LENGTH(prd_key)) AS prd_key,
                    prd_nm,
                    COALESCE(prd_cost, 0) AS prd_cost, 
                    CASE UPPER(TRIM(prd_line))
                        WHEN 'M' THEN 'Mountain'
                        WHEN 'R' THEN 'Road'
                        WHEN 'S' THEN 'Other Sales'
                        WHEN 'T' THEN 'Touring'
                        ELSE 'N/A'
                    END AS prd_line,
                    CAST(prd_start_dt AS DATE) AS prd_start_dt,
                    CAST(LEAD(prd_start_dt) OVER(PARTITION BY prd_key ORDER BY prd_start_dt) - INTERVAL '1 DAY' AS DATE) AS prd_end_dt
                FROM bronze.crm_prd_info;
             l_end_time := clock_timestamp();
            GET DIAGNOSTICS table_rows = ROW_COUNT;
            RAISE NOTICE '>> silver.crm_prd_info complete.loaded % rows in: %',
                table_rows, l_end_time - l_start_time; 
        EXCEPTION 
            WHEN OTHERS THEN
            RAISE NOTICE 'silver.crm_prd_info failed.';
            GET STACKED DIAGNOSTICS 
                sd_message = MESSAGE_TEXT,
                sd_detail = PG_EXCEPTION_DETAIL,
                sd_context = PG_EXCEPTION_CONTEXT,
                sd_hint = PG_EXCEPTION_HINT;
            RAISE EXCEPTION 
                'Table: silver.crm_prd_info
                 SQLSTATE: %
                 Message: %
                 Detail: %
                 error_line: %
                 error_hint: %',
                SQLSTATE, sd_message, sd_detail, sd_context, sd_hint;
        END;
-- silver.crm_sales_details table 
        BEGIN
            RAISE NOTICE '>>Truncating table: silver.crm_sales_details';
            TRUNCATE TABLE silver.crm_sales_details;
            
            RAISE NOTICE '>>Inserting Data Into: silver.crm_sales_details';
            l_start_time := clock_timestamp();
            INSERT INTO silver.crm_sales_details(
                sls_ord_num, 
                sls_prd_key,
                sls_cust_id,
                sls_order_dt,
                sls_ship_dt,
                sls_due_dt,
                sls_sales,
                sls_quantity,
                sls_price
                )
                SELECT 
                    sls_ord_num, 
                    sls_prd_key,
                    sls_cust_id,
                    CASE 
                        WHEN sls_order_dt = 0 OR LENGTH(CAST(sls_order_dt AS TEXT)) != 8 THEN NULL
                        ELSE TO_DATE(sls_order_dt::TEXT, 'YYYYMMDD') 
                    END AS sls_order_dt,
                    CASE 
                        WHEN sls_ship_dt = 0 OR LENGTH(CAST(sls_ship_dt AS TEXT)) != 8 THEN NULL
                        ELSE TO_DATE(sls_ship_dt::TEXT, 'YYYYMMDD') 
                    END AS sls_ship_dt,
                    CASE 
                        WHEN sls_due_dt = 0 OR LENGTH(CAST(sls_due_dt AS TEXT)) != 8 THEN NULL
                        ELSE TO_DATE(sls_due_dt::TEXT, 'YYYYMMDD') 
                    END AS sls_due_dt,
                    CASE 
                        WHEN sls_sales IS NULL OR sls_sales <= 0 OR sls_sales != sls_quantity * ABS(sls_price) 
                            THEN sls_quantity * ABS(sls_price)
                        ELSE sls_sales
                    END AS sls_sales, 
                    sls_quantity, 
                    CASE 
                        WHEN sls_price IS NULL OR sls_price <= 0 
                            THEN sls_sales/NULLIF(sls_quantity,0)
                        ELSE sls_price
                    END AS sls_price
                FROM bronze.crm_sales_details;
             l_end_time := clock_timestamp();
            GET DIAGNOSTICS table_rows = ROW_COUNT;
            RAISE NOTICE '>> silver.crm_sales_details complete. Loaded % rows in: %',
                table_rows, l_end_time - l_start_time; 
        EXCEPTION 
            WHEN OTHERS THEN
            RAISE NOTICE 'silver.crm_sales_details failed.';
            GET STACKED DIAGNOSTICS 
                sd_message = MESSAGE_TEXT,
                sd_detail = PG_EXCEPTION_DETAIL,
                sd_context = PG_EXCEPTION_CONTEXT,
                sd_hint = PG_EXCEPTION_HINT;
            RAISE EXCEPTION 
                'Table: silver.crm_sales_details
                 SQLSTATE: %
                 Message: %
                 Detail: %
                 error_line: %
                 error_hint: %',
                SQLSTATE, sd_message, sd_detail, sd_context, sd_hint;
        END;

            RAISE NOTICE '-------------------------------';
            RAISE NOTICE 'Loading ERP Tables';
            RAISE NOTICE '-------------------------------';
-- silver.erp_cust_az12 table 
        BEGIN
            RAISE NOTICE '>>Truncating table: silver.erp_cust_az12';
            TRUNCATE TABLE silver.erp_cust_az12;
            
            RAISE NOTICE '>>Inserting Data Into: silver.erp_cust_az12';
            l_start_time := clock_timestamp();
            INSERT INTO silver.erp_cust_az12 (
                cid,
                bdate,
                gen
                )
                SELECT 
                    CASE
                        WHEN cid LIKE 'NAS%' THEN SUBSTRING(cid,4,LENGTH(cid))
                        ELSE cid
                    END AS cid, 
                    CASE 
                        WHEN bdate > CURRENT_DATE THEN NULL
                        ELSE bdate
                    END AS bdate,
                    CASE
                        WHEN UPPER(TRIM(gen)) IN ('F', 'FEMALE') THEN 'Female'
                        WHEN UPPER(TRIM(gen)) IN ('M', 'MALE') THEN 'Male'
                        ELSE 'N/A'
                    END AS gen
                FROM bronze.erp_cust_az12;
             l_end_time := clock_timestamp();
            GET DIAGNOSTICS table_rows = ROW_COUNT;
            RAISE NOTICE '>> silver.erp_cust_az12 complete. loaded % rows in: %',
                table_rows, l_end_time - l_start_time; 
        EXCEPTION 
            WHEN OTHERS THEN
            RAISE NOTICE 'silver.erp_cust_az12 failed.';
            GET STACKED DIAGNOSTICS 
                sd_message = MESSAGE_TEXT,
                sd_detail = PG_EXCEPTION_DETAIL,
                sd_context = PG_EXCEPTION_CONTEXT,
                sd_hint = PG_EXCEPTION_HINT;
            RAISE EXCEPTION 
                'Table: silver.erp_cust_az12
                 SQLSTATE: %
                 Message: %
                 Detail: %
                 error_line: %
                 error_hint: %',
                SQLSTATE, sd_message, sd_detail, sd_context, sd_hint;
        END;
-- silver.erp_loc_a101 table 
        BEGIN
            RAISE NOTICE '>>Truncating table: silver.erp_loc_a101';
            TRUNCATE TABLE silver.erp_loc_a101;
            
            RAISE NOTICE '>>Inserting Data Into: silver.erp_loc_a101';
            l_start_time := clock_timestamp();
            INSERT INTO silver.erp_loc_a101 (
                cid,
                cntry
                )
                SELECT 
                    REPLACE(cid,'-','') AS cid,
                    CASE
                        WHEN TRIM(cntry) = 'DE' THEN 'Germany'
                        WHEN TRIM(cntry) IN ('US', 'USA') THEN 'United States'
                        WHEN TRIM(cntry) = '' OR cntry IS NULL THEN 'N/A'
                        ELSE TRIM(cntry)
                    END AS cntry
                FROM bronze.erp_loc_a101;
            l_end_time := clock_timestamp();
            GET DIAGNOSTICS table_rows = ROW_COUNT;
            RAISE NOTICE '>> silver.erp_loc_a101 complete. Loaded % rows in: %',
                table_rows, l_end_time - l_start_time; 
        EXCEPTION 
            WHEN OTHERS THEN
            RAISE NOTICE 'silver.erp_loc_a101 failed.';
            GET STACKED DIAGNOSTICS 
                sd_message = MESSAGE_TEXT,
                sd_detail = PG_EXCEPTION_DETAIL,
                sd_context = PG_EXCEPTION_CONTEXT,
                sd_hint = PG_EXCEPTION_HINT;
            RAISE EXCEPTION 
                'Table: silver.erp_loc_a101
                 SQLSTATE: %
                 Message: %
                 Detail: %
                 error_line: %
                 error_hint: %',
                SQLSTATE, sd_message, sd_detail, sd_context, sd_hint;
        END;
-- silver.erp_px_cat_g1v2 table 
        BEGIN
            RAISE NOTICE '>>Truncating table: silver.erp_px_cat_g1v2';
            TRUNCATE TABLE silver.erp_px_cat_g1v2;
            
            RAISE NOTICE '>>Inserting Data Into: silver.erp_px_cat_g1v2';
            l_start_time := clock_timestamp();
            INSERT INTO silver.erp_px_cat_g1v2 (
                id,
                cat,
                subcat,
                maintenance
                )
                SELECT 
                    id,
                    cat,
                    subcat,
                    maintenance
                FROM bronze.erp_px_cat_g1v2; 
            l_end_time := clock_timestamp();
            GET DIAGNOSTICS table_rows = ROW_COUNT;
            RAISE NOTICE '>> silver.erp_px_cat_g1v2 complete. Loaded % rows in: %',
                table_rows, l_end_time - l_start_time; 
        EXCEPTION 
            WHEN OTHERS THEN
            RAISE NOTICE 'silver.erp_px_cat_g1v2 failed.';
            GET STACKED DIAGNOSTICS 
                sd_message = MESSAGE_TEXT,
                sd_detail = PG_EXCEPTION_DETAIL,
                sd_context = PG_EXCEPTION_CONTEXT,
                sd_hint = PG_EXCEPTION_HINT;
            RAISE EXCEPTION 
                'Table: silver.erp_px_cat_g1v2
                 SQLSTATE: %
                 Message: %
                 Detail: %
                 error_line: %
                 error_hint: %',
                SQLSTATE, sd_message, sd_detail, sd_context, sd_hint;
        END;    
    proc_end := clock_timestamp();
        RAISE NOTICE '=============================================';
        RAISE NOTICE 'silver Layer loaded successfully';
        RAISE NOTICE '=============================================';
         RAISE NOTICE '---------------------------------------------';
        RAISE NOTICE 'Total time to load silver layer: %',
            proc_end - proc_start;
         RAISE NOTICE '---------------------------------------------';
    END;
$$;

CALL silver.load_silver();
